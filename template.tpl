___SANDBOXED_JS_FOR_WEB_TEMPLATE___

const gtagSet = require('gtagSet');
const setDefaultConsentState = require('setDefaultConsentState');
const updateConsentState = require('updateConsentState');
const injectScript = require('injectScript');
const queryPermission = require('queryPermission');
const callInWindow = require('callInWindow');
const setInWindow = require('setInWindow');
const makeNumber = require('makeNumber');
const log = require('logToConsole');

// 1. Declare Permissor's Google CMP Developer ID
const PERMISSOR_DEVELOPER_ID = 'dZmFiNj';
gtagSet('developer_id.' + PERMISSOR_DEVELOPER_ID, true);

// 2. Set default consent state (all denied)
const defaultConsent = {
  'ad_storage': 'denied',
  'ad_user_data': 'denied',
  'ad_personalization': 'denied',
  'analytics_storage': 'denied',
  'functionality_storage': 'denied',
  'security_storage': 'granted',
  'personalization_storage': 'denied',
  'wait_for_update': makeNumber(data.waitForUpdate) || 500
};

// Resolve GCM default region. Keep in sync with
// GenerateUnifiedLoaderJob::resolveGcmRegion (PHP) and
// resources/widget/composables/useThirdPartyConsent.js resolveGcmRegion (JS).
const resolveGcmRegion = function() {
  if (data.defaultConsentRegion === 'global') {
    return null;
  }
  return ['EEA', 'GB'];
};

const region = resolveGcmRegion();
if (region !== null) {
  defaultConsent.region = region;
}

setDefaultConsentState(defaultConsent);

// 3. Set additional Google signals
gtagSet('ads_data_redaction', true);
gtagSet('url_passthrough', true);

// 4. Register callback for consent updates from Permissor widget
// Keep TCF_GCM_MAPPING + resolveGcmSignal in sync with resources/widget/utils/tcfMapping.js
const TCF_GCM_MAPPING = {
  ad_storage:              { req: [1], any: [] },
  ad_user_data:            { req: [1], any: [2, 3, 4, 5, 6, 7, 9, 10] },
  ad_personalization:      { req: [1], any: [3, 4] },
  analytics_storage:       { req: [1], any: [7, 8, 9, 10] },
  functionality_storage:   { req: [1], any: [11] },
  security_storage:        { req: [], any: [] },
  personalization_storage: { req: [1], any: [5, 6] }
};

const resolveGcmSignal = function(rule, pc, pli) {
  if (rule.req.length === 0 && rule.any.length === 0) {
    return 'granted';
  }
  const hasBasis = function(pid) {
    return pc[pid] === true || pli[pid] === true;
  };
  if (!rule.req.every(hasBasis)) {
    return 'denied';
  }
  if (rule.any.length === 0) {
    return 'granted';
  }
  return rule.any.some(hasBasis) ? 'granted' : 'denied';
};

setInWindow('__permissorGtmConsentUpdate', function(consentData) {
  if (!consentData) {
    return;
  }

  if (consentData.tcf) {
    const pc = consentData.tcf.purposeConsents || {};
    const pli = consentData.tcf.purposeLegitimateInterests || {};

    updateConsentState({
      'ad_storage':              resolveGcmSignal(TCF_GCM_MAPPING.ad_storage, pc, pli),
      'ad_user_data':            resolveGcmSignal(TCF_GCM_MAPPING.ad_user_data, pc, pli),
      'ad_personalization':      resolveGcmSignal(TCF_GCM_MAPPING.ad_personalization, pc, pli),
      'analytics_storage':       resolveGcmSignal(TCF_GCM_MAPPING.analytics_storage, pc, pli),
      'functionality_storage':   resolveGcmSignal(TCF_GCM_MAPPING.functionality_storage, pc, pli),
      'security_storage':        'granted',
      'personalization_storage': resolveGcmSignal(TCF_GCM_MAPPING.personalization_storage, pc, pli)
    });
    return;
  }

  if (consentData.categories) {
    const categories = consentData.categories;

    const marketingGranted = categories.marketing ? 'granted' : 'denied';
    const analyticsGranted = categories.analytics ? 'granted' : 'denied';
    const functionalGranted = categories.functional ? 'granted' : 'denied';

    updateConsentState({
      'ad_storage': marketingGranted,
      'ad_user_data': marketingGranted,
      'ad_personalization': marketingGranted,
      'analytics_storage': analyticsGranted,
      'functionality_storage': functionalGranted,
      'security_storage': 'granted',
      'personalization_storage': marketingGranted
    });
  }
}, true);

// 5. Resolve loader URL from connection code (companyId:websiteId) and inject it
const code = data.connectionCode;
const sep = code.indexOf(':');
const companyId = code.substring(0, sep);
const websiteId = code.substring(sep + 1);

let baseUrl = data.appBaseUrl;
if (baseUrl.charAt(baseUrl.length - 1) === '/') {
  baseUrl = baseUrl.substring(0, baseUrl.length - 1);
}

const loaderUrl = baseUrl + '/loaders/' + companyId + '/' + websiteId + '/loader.js';

if (queryPermission('inject_script', loaderUrl)) {
  injectScript(loaderUrl, function() {
    log('Permissor: loader script loaded successfully');
    data.gtmOnSuccess();
  }, function() {
    log('Permissor: failed to load loader script');
    data.gtmOnFailure();
  }, 'permissorLoader');
} else {
  log('Permissor: inject_script not permitted for loader URL');
  data.gtmOnFailure();
}


